# ──────────────────────────────────────────────
# Code Refactorer LLM — Variables d'environnement
# Copiez ce fichier en .env et ajustez les valeurs.
# ──────────────────────────────────────────────

# ── LM Studio ─────────────────────────────────
# URL du serveur local LM Studio (ne pas modifier sauf si port personnalisé)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Clé API fictive requise par le SDK OpenAI (LM Studio n'en a pas besoin)
LM_STUDIO_API_KEY=lm-studio

# Identifiant du modèle chargé dans LM Studio
# Exemples : "qwen2.5-coder-7b-instruct", "deepseek-coder-v2-lite-instruct"
# Laissez "local-model" si LM Studio accepte n'importe quel identifiant.
LM_STUDIO_MODEL=local-model

# Température (0.0 = déterministe, 1.0 = créatif) — recommandé : 0.1 à 0.3 pour le code
LM_STUDIO_TEMPERATURE=0.2

# Nombre maximum de tokens générés
LM_STUDIO_MAX_TOKENS=8192

# Timeout en secondes pour les requêtes longues
LM_STUDIO_TIMEOUT=120

# ── Application ───────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=7860

# Mettre à true pour obtenir un lien public Gradio (nécessite une connexion internet)
APP_SHARE=false
